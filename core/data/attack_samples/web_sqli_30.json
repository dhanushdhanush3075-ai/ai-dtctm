  {"id": 22, "payload": "'; SELECT pg_sleep(5)--",                        "type": "time",     "what": "PostgreSQL time-based blind injection",                               "expected_vulnerable": "5 second delay on response", "expected_secured": "Response immediate"},
  {"id": 23, "payload": "' AND (SELECT COUNT(*) FROM users)>0--",         "type": "blind",    "what": "Boolean blind — response changes if users table exists",               "expected_vulnerable": "Different HTTP response body vs normal", "expected_secured": "Identical response — no information leak"},
  {"id": 24, "payload": "' AND ASCII(SUBSTR(password,1,1))>64--",         "type": "blind",    "what": "Char-by-char password extraction via response difference",             "expected_vulnerable": "Response differs → binary search reveals password", "expected_secured": "Identical response"},
