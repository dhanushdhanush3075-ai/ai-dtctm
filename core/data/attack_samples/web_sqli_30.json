  {"id": 1,  "payload": "' OR '1'='1",                                   "type": "boolean",  "what": "Classic auth bypass — WHERE clause always true",                          "expected_vulnerable": "HTTP 200 + dashboard/welcome page", "expected_secured": "HTTP 400/401 — Invalid credentials"},
  {"id": 2,  "payload": "' OR 1=1--",                                    "type": "boolean",  "what": "Numeric boolean + SQL comment strips password check",                   "expected_vulnerable": "Login succeeds, redirects to app", "expected_secured": "Login fails, stays on /login"},
  {"id": 3,  "payload": "admin'--",                                       "type": "boolean",  "what": "Comment truncates query — password condition removed",                  "expected_vulnerable": "Logged in as admin without password", "expected_secured": "401 Unauthorized"},
  {"id": 4,  "payload": "' OR ''=''",                                     "type": "boolean",  "what": "Empty string equality — always evaluates to true",                      "expected_vulnerable": "Auth bypass, session cookie set", "expected_secured": "Credentials rejected"},
  {"id": 5,  "payload": "' OR 'x'='x",                                   "type": "boolean",  "what": "Non-obvious string equality bypass",                                   "expected_vulnerable": "Access granted", "expected_secured": "Access denied"},
