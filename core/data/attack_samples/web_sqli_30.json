  {"id": 8,  "payload": "') OR ('1'='1",                                 "type": "boolean",  "what": "Parenthesis-wrapped bypass for grouped WHERE clauses",                  "expected_vulnerable": "Bracket logic collapses, auth bypassed", "expected_secured": "Syntax rejected"},
