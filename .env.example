# AI-DTCTM — Environment Variable Template
# Copy this file to `.env` and fill in your actual values.
# NEVER commit `.env` to git. It's already in .gitignore.

# ── Profile ──────────────────────────────────────────────────────
# dev  = full logging, mock fallbacks if APIs fail
# demo = optimised for live presentations (caching aggressive)
# prod = minimal logging, strict error handling
DTCTM_PROFILE=dev

# ── App Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))") ──
DTCTM_SECRET=replace-with-a-real-random-32-char-string

# ── External APIs (all FREE — see DAY1_SETUP_GUIDE.md for registration) ──
VIRUSTOTAL_API_KEY=
GOOGLE_SB_API_KEY=
URLSCAN_API_KEY=
PHISHTANK_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
SHODAN_API_KEY=

# ── Database (SQLite is the default, works out of the box) ───────
DTCTM_DB_TYPE=sqlite
DTCTM_DB_HOST=localhost
DTCTM_DB_PORT=3306
DTCTM_DB_USER=root
DTCTM_DB_PASS=
DTCTM_DB_NAME=securex_db

# ── Docker Digital Twin config ───────────────────────────────────
DOCKER_TWIN_NETWORK=aidtctm_twin_net
DOCKER_DVWA_PORT=8081
DOCKER_WEBGOAT_PORT=8082
DOCKER_JUICESHOP_PORT=8083

# ── Cache ────────────────────────────────────────────────────────
CACHE_DEFAULT_TTL=300
