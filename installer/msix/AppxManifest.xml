<?xml version="1.0" encoding="utf-8"?>
<!--
  AI-DTCTM — MSIX manifest for Microsoft Store submission
  ════════════════════════════════════════════════════════════════
  This file declares the app to Windows Store. Once submitted and
  accepted, Microsoft signs the .msix bundle with their certificate
  which is trusted by WDAC code integrity policies by default —
  meaning your app will run on locked-down corporate machines too.
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

  <Identity
      Name="DhanushS.AIDTCTM"
      Publisher="CN=AI-DTCTM Code Signing, O=DHANUSH S, C=IN"
      Version="1.0.0.0"
      ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>AI-DTCTM — Forensic Engine</DisplayName>
    <PublisherDisplayName>DHANUSH S · MCE</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>
      AI Digital Twin Cybersecurity Threat Management — forensic engine
      for malware detection, vulnerability discovery, and live
      exploitation testing. Pure-NumPy ML, Docker-isolated digital
      twins for source / DB / APK analysis, 22 SQL injection payload
      library, NIST-mapped mitigation playbook, cloud sync.
    </Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
        Name="Windows.Desktop"
        MinVersion="10.0.17763.0"
        MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App"
        Executable="AI-DTCTM-Launcher.exe"
        EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="AI-DTCTM"
          Description="Forensic engine for malware detection and digital-twin attack labs."
          BackgroundColor="#0F172A"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Wide310x150Logo="Assets\Wide310x150Logo.png"
            Square71x71Logo="Assets\Square71x71Logo.png"
            Square310x310Logo="Assets\Square310x310Logo.png"
            ShortName="AI-DTCTM" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#0F172A" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
